#!/usr/bin/env bash
set -u

json_output=0
no_trace=0
trace_target=""

usage() {
  cat <<'EOF'
Usage: network-ips [--json] [--no-trace] [--trace-target HOST] [--help]

Options:
  --json               Output JSON
  --no-trace           Skip traceroute
  --trace-target HOST  Override traceroute target
  --help               Show this help
EOF
}

while [ $# -gt 0 ]; do
  case "$1" in
    --json)
      json_output=1
      ;;
    --no-trace)
      no_trace=1
      ;;
    --trace-target)
      shift
      if [ $# -eq 0 ]; then
        echo "Missing value for --trace-target" >&2
        exit 1
      fi
      trace_target="$1"
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    *)
      echo "Unknown option: $1" >&2
      usage >&2
      exit 1
      ;;
  esac
  shift
done

command_exists() {
  command -v "$1" >/dev/null 2>&1
}

json_escape() {
  local value="$1"
  value=${value//\\/\\\\}
  value=${value//\"/\\\"}
  value=${value//$'\n'/\\n}
  value=${value//$'\r'/\\r}
  value=${value//$'\t'/\\t}
  printf '%s' "$value"
}

is_private_ipv4() {
  case "$1" in
    10.*|192.168.*)
      return 0
      ;;
    172.1[6-9].*|172.2[0-9].*|172.3[0-1].*)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

is_tailscale_ipv4() {
  case "$1" in
    100.6[4-9].*|100.[7-9][0-9].*|100.1[01][0-9].*|100.12[0-7].*)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

is_tailscale_ipv6() {
  local value
  value="$(printf '%s' "$1" | tr '[:upper:]' '[:lower:]')"
  case "$value" in
    fd7a:115c:a1e0:*)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

is_tailscale_address() {
  is_tailscale_ipv4 "$1" || is_tailscale_ipv6 "$1"
}

detect_os() {
  case "$(uname -s)" in
    Darwin)
      echo "macos"
      ;;
    Linux)
      echo "linux"
      ;;
    *)
      echo "other"
      ;;
  esac
}

collect_addresses() {
  local os
  os="$(detect_os)"

  if [ "$os" = "macos" ] && command_exists ifconfig; then
    ifconfig | awk '
      /^[^ \t]/ { iface=$1; sub(":", "", iface); active=1 }
      /status: inactive/ { active=0 }
      /^[ \t]+inet / && active { print iface "\tinet\t" $2 }
      /^[ \t]+inet6 / && active { ip=$2; sub(/%.*/, "", ip); print iface "\tinet6\t" ip }
    '
    return
  fi

  if [ "$os" = "linux" ] && command_exists ip; then
    ip -o addr show up | awk '
      {
        addr=$4
        sub(/\/.*/, "", addr)
        sub(/%.*/, "", addr)
        print $2 "\t" $3 "\t" addr
      }
    '
    return
  fi

  if command_exists ifconfig; then
    ifconfig | awk '
      /^[^ \t]/ { iface=$1; sub(":", "", iface); active=1 }
      /status: inactive/ { active=0 }
      /^[ \t]+inet / && active { print iface "\tinet\t" $2 }
      /^[ \t]+inet6 / && active { ip=$2; sub(/%.*/, "", ip); print iface "\tinet6\t" ip }
    '
  fi
}

dedupe_lines() {
  awk 'NF && !seen[$0]++'
}

build_local_output() {
  local private_lines=""
  local fallback_lines=""
  local iface family addr line

  while IFS=$'\t' read -r iface family addr; do
    [ -n "${iface:-}" ] || continue
    [ "$family" = "inet" ] || continue

    case "$iface" in
      lo*|utun*|tailscale*)
        continue
        ;;
    esac

    case "$addr" in
      127.*|169.254.*)
        continue
        ;;
    esac

    if is_tailscale_ipv4 "$addr"; then
      continue
    fi

    line="${iface}  ${addr}"
    if is_private_ipv4 "$addr"; then
      private_lines+="${line}"$'\n'
    else
      fallback_lines+="${line}"$'\n'
    fi
  done < <(collect_addresses)

  if [ -n "$private_lines" ]; then
    printf '%s' "$private_lines" | dedupe_lines
    return
  fi

  if [ -n "$fallback_lines" ]; then
    printf '%s' "$fallback_lines" | dedupe_lines
    return
  fi

  printf 'Not detected'
}

build_tailscale_output() {
  local cli_output=""
  local scanned=""
  local iface family addr

  if command_exists tailscale; then
    cli_output="$(
      {
        tailscale ip -4 2>/dev/null || true
        tailscale ip -6 2>/dev/null || true
      } | dedupe_lines
    )"

    if [ -n "$cli_output" ]; then
      printf 'Detected via CLI\n%s' "$cli_output"
      return
    fi

    printf 'CLI found, no active Tailscale IP'
    return
  fi

  while IFS=$'\t' read -r iface family addr; do
    [ -n "${iface:-}" ] || continue
    if is_tailscale_address "$addr" || [[ "$iface" == tailscale* ]]; then
      scanned+="${addr}"$'\n'
    fi
  done < <(collect_addresses)

  if [ -n "$scanned" ]; then
    printf 'Detected via interface scan\n%s' "$(printf '%s' "$scanned" | dedupe_lines)"
    return
  fi

  if [ -d "/Applications/Tailscale.app" ]; then
    printf 'Install found, no active Tailscale IP'
    return
  fi

  printf 'Not detected'
}

fetch_public_ip() {
  local payload=""

  if command_exists curl; then
    payload="$(curl -fsS --max-time 10 https://api.ipify.org 2>/dev/null || true)"
  elif command_exists wget; then
    payload="$(wget -qO- https://api.ipify.org 2>/dev/null || true)"
  fi

  payload="$(printf '%s' "$payload" | tr -d '\r' | tr -d '\n')"

  if [ -n "$payload" ]; then
    printf '%s\nSource: api.ipify.org' "$payload"
    return
  fi

  printf 'n/a\nError: public IP lookup failed.'
}

run_traceroute() {
  local target="$1"
  local os
  os="$(detect_os)"

  if [ "$os" = "macos" ]; then
    if [ -x /usr/sbin/traceroute ]; then
      /usr/sbin/traceroute -m 12 -q 1 -w 1 "$target" 2>&1 || true
      return
    fi
    if command_exists traceroute; then
      traceroute -m 12 -q 1 -w 1 "$target" 2>&1 || true
      return
    fi
  fi

  if [ "$os" = "linux" ]; then
    if command_exists traceroute; then
      traceroute -n -m 12 -q 1 -w 1 "$target" 2>&1 || true
      return
    fi
    if command_exists tracepath; then
      tracepath -n "$target" 2>&1 || true
      return
    fi
  fi

  printf 'Traceroute command not available.'
}

public_block="$(fetch_public_ip)"
public_ip="$(printf '%s\n' "$public_block" | sed -n '1p')"
public_status="$(printf '%s\n' "$public_block" | sed -n '2p')"
local_ip_output="$(build_local_output)"
tailscale_output="$(build_tailscale_output)"
traceroute_output=""

if [ "$no_trace" -eq 0 ]; then
  if [ -n "$trace_target" ]; then
    traceroute_output="$(run_traceroute "$trace_target")"
  elif [ "$public_ip" != "n/a" ] && [ -n "$public_ip" ]; then
    traceroute_output="$(run_traceroute "$public_ip")"
  else
    traceroute_output="Skipped: public IP unavailable."
  fi
fi

if [ "$json_output" -eq 1 ]; then
  printf '{\n'
  printf '  "public_ip": "%s",\n' "$(json_escape "$public_ip")"
  printf '  "public_status": "%s",\n' "$(json_escape "$public_status")"
  printf '  "local_ip": "%s",\n' "$(json_escape "$local_ip_output")"
  printf '  "tailscale": "%s"' "$(json_escape "$tailscale_output")"
  if [ "$no_trace" -eq 0 ]; then
    printf ',\n  "traceroute": "%s"\n' "$(json_escape "$traceroute_output")"
  else
    printf '\n'
  fi
  printf '}\n'
  exit 0
fi

printf 'Public IP\n%s\n%s\n\n' "$public_ip" "$public_status"
printf 'Local IP\n%s\n\n' "$local_ip_output"
printf 'Tailscale\n%s\n' "$tailscale_output"

if [ "$no_trace" -eq 0 ]; then
  printf '\n\nTraceroute\n%s\n' "$traceroute_output"
fi
