<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="920"
        d:DesignHeight="760"
        x:Class="NetworkIPs.Windows.MainWindow"
        Title="Network IPs"
        Width="920"
        Height="760"
        MinWidth="760"
        MinHeight="620">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24"
                    Spacing="14">
            <TextBlock Text="Public IP"
                       FontSize="13"
                       Opacity="0.72" />
            <TextBlock x:Name="PublicIPText"
                       Text="..."
                       FontFamily="Cascadia Code, Consolas, Courier New"
                       FontSize="30"
                       FontWeight="SemiBold"
                       TextWrapping="Wrap" />
            <TextBlock x:Name="PublicStatusText"
                       Text="Ready."
                       FontFamily="Cascadia Code, Consolas, Courier New"
                       FontSize="11"
                       Opacity="0.72"
                       TextWrapping="Wrap" />

            <TextBlock Text="Local IP"
                       Margin="0,6,0,0"
                       FontSize="13"
                       Opacity="0.72" />
            <TextBlock x:Name="LocalIPText"
                       Text="Detecting..."
                       FontFamily="Cascadia Code, Consolas, Courier New"
                       FontSize="13"
                       TextWrapping="Wrap" />

            <TextBlock Text="Tailscale"
                       Margin="0,6,0,0"
                       FontSize="13"
                       Opacity="0.72" />
            <TextBlock x:Name="TailscaleText"
                       Text="Detecting..."
                       FontFamily="Cascadia Code, Consolas, Courier New"
                       FontSize="13"
                       TextWrapping="Wrap" />

            <Button x:Name="RefreshButton"
                    Content="Refresh"
                    Width="110"
                    HorizontalAlignment="Left"
                    Click="RefreshButton_OnClick" />

            <TextBlock Text="Traceroute"
                       Margin="0,6,0,0"
                       FontSize="13"
                       Opacity="0.72" />
            <TextBox x:Name="TracerouteText"
                     Height="320"
                     IsReadOnly="True"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     FontFamily="Cascadia Code, Consolas, Courier New"
                     Text="Waiting for public IP..." />
        </StackPanel>
    </ScrollViewer>
</Window>
